#!/bin/bash

# arcalos:summary=Set the branch for arcalos's git repository.
# arcalos:args=<master|rc|dev>

if (($# == 0)); then
  echo "Usage: arcalos-branch-set [master|rc|dev]"
  exit 1
else
  branch="$1"
fi

if [[ $branch != "master" && $branch != "rc" && $branch != "dev" ]]; then
  echo "Error: Invalid branch '$branch'. Must be one of: master, rc, dev"
  exit 1
fi

git -C $ARCALOS_PATH switch $branch
