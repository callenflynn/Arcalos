#!/bin/bash

# arcalos:summary=Edit, set, or reset About branding
# arcalos:group=branding
# arcalos:name=about
# arcalos:args=<image|text|reset>
# arcalos:examples=arcalos branding about image | arcalos branding about text | arcalos branding about reset

set -euo pipefail

SOURCE_DIR="${XDG_PICTURES_DIR:-$HOME/Pictures}"

case "${1:-}" in
image)
  image=$(arcalos-menu-file "Pick png/svg from $SOURCE_DIR" "${SOURCE_DIR}" "svg png")
  if [[ -n $image ]] && arcalos-transcode-ascii "$image" ~/.config/arcalos/branding/about.txt --width 54 --height 26; then
    arcalos-launch-about >/dev/null 2>&1
  fi
  ;;
text)
  arcalos-launch-editor ~/.config/arcalos/branding/about.txt >/dev/null 2>&1 && arcalos-launch-about >/dev/null 2>&1
  ;;
reset)
  cp "$ARCALOS_PATH/icon.txt" ~/.config/arcalos/branding/about.txt && arcalos-launch-about >/dev/null 2>&1
  ;;
*)
  echo "Usage: arcalos-branding-about <image|text|reset>" >&2
  exit 1
  ;;
esac
