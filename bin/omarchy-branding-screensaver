#!/bin/bash

# arcalos:summary=Edit, set, or reset screensaver branding
# arcalos:group=branding
# arcalos:name=screensaver
# arcalos:args=<image|text|reset>
# arcalos:examples=arcalos branding screensaver image | arcalos branding screensaver text | arcalos branding screensaver reset

set -euo pipefail

SOURCE_DIR="${XDG_PICTURES_DIR:-$HOME/Pictures}"

case "${1:-}" in
image)
  image=$(arcalos-menu-file "Pick png/svg from $SOURCE_DIR" "${SOURCE_DIR}" "svg png")
  if [[ -n $image ]] && arcalos-transcode-ascii "$image" ~/.config/arcalos/branding/screensaver.txt; then
    arcalos-launch-screensaver force >/dev/null 2>&1
  fi
  ;;
text)
  arcalos-launch-editor ~/.config/arcalos/branding/screensaver.txt >/dev/null 2>&1 && arcalos-launch-screensaver force >/dev/null 2>&1
  ;;
reset)
  cp "$ARCALOS_PATH/logo.txt" ~/.config/arcalos/branding/screensaver.txt && arcalos-launch-screensaver force >/dev/null 2>&1
  ;;
*)
  echo "Usage: arcalos-branding-screensaver <image|text|reset>" >&2
  exit 1
  ;;
esac
