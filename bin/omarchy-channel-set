#!/bin/bash

# arcalos:summary=Set the arcalos channel, which dictates what git branch and package repository is used.
# arcalos:args=<stable|rc|edge|dev>
# arcalos:requires-sudo=true

if (($# == 0)); then
  echo "Usage: arcalos-channel-set [stable|rc|edge|dev]"
  exit 1
else
  channel="$1"
fi

case "$channel" in
"stable") arcalos-branch-set "master" && arcalos-refresh-pacman "stable" ;;
"rc") arcalos-branch-set "rc" && arcalos-refresh-pacman "rc" ;;
"edge") arcalos-branch-set "master" && arcalos-refresh-pacman "edge" ;;
"dev") arcalos-branch-set "dev" && arcalos-refresh-pacman "edge" ;;
*) echo "Unknown channel: $channel"; exit 1; ;;
esac

arcalos-update -y
