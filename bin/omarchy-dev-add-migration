#!/bin/bash

# arcalos:summary=Creates a new arcalos migration named after the unix timestamp of the last commit.

cd ~/.local/share/arcalos
migration_file="$HOME/.local/share/arcalos/migrations/$(git log -1 --format=%cd --date=unix).sh"
touch $migration_file

if [[ $1 != "--no-edit" ]]; then
  nvim $migration_file
fi

echo $migration_file
