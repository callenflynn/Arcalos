#!/bin/bash

# arcalos:summary=Finish the installation of arcalos with items that can only be done after logging in.
# arcalos:requires-sudo=true

set -e

FIRST_RUN_MODE=~/.local/state/arcalos/first-run.mode

if [[ -f $FIRST_RUN_MODE ]]; then
  rm -f "$FIRST_RUN_MODE"

  bash "$ARCALOS_PATH/install/first-run/battery-monitor.sh"
  bash "$ARCALOS_PATH/install/first-run/recover-internal-monitor.sh"
  bash "$ARCALOS_PATH/install/first-run/cleanup-reboot-sudoers.sh"
  bash "$ARCALOS_PATH/install/first-run/firewall.sh"
  bash "$ARCALOS_PATH/install/first-run/dns-resolver.sh"
  bash "$ARCALOS_PATH/install/first-run/gnome-theme.sh"
  bash "$ARCALOS_PATH/install/first-run/gdk-scale.sh"
  bash "$ARCALOS_PATH/install/first-run/swayosd.sh"
  bash "$ARCALOS_PATH/install/first-run/gtk-primary-paste.sh"
  bash "$ARCALOS_PATH/install/first-run/elephant.sh"
  arcalos-hook-install post-update "$ARCALOS_PATH/install/first-run/install-voxtype.hook"
  sudo rm -f /etc/sudoers.d/first-run

  bash "$ARCALOS_PATH/install/first-run/welcome.sh"
  bash "$ARCALOS_PATH/install/first-run/wifi.sh"
fi
