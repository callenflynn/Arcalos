#!/bin/bash

# arcalos:summary=Install Heroic Games Launcher (Epic, GOG, Amazon Prime Gaming) with graphics drivers.
# arcalos:requires-sudo=true

set -e

echo "Installing Heroic Games Launcher..."
arcalos-pkg-add heroic-games-launcher-bin
arcalos-install-gaming-gpu-lib32

setsid gtk-launch heroic >/dev/null 2>&1 &
