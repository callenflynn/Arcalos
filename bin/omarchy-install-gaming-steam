#!/bin/bash

# arcalos:summary=Install Steam and graphics drivers selected for this system
# arcalos:requires-sudo=true

set -e

echo "Installing Steam..."
arcalos-pkg-add steam
arcalos-install-gaming-gpu-lib32

echo ""
echo "Steam will start automatically now. This might take a while..."

setsid gtk-launch steam >/dev/null 2>&1 &
