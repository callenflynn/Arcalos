#!/bin/bash

# arcalos:summary=Launch a floating terminal with the arcalos presentation wrapper
# arcalos:args=<command>

cmd="$*"
exec setsid uwsm-app -- xdg-terminal-exec --app-id=org.arcalos.terminal --title=arcalos -e bash -c "arcalos-show-logo; $cmd; if (( \$? != 130 )); then arcalos-show-done; fi"
