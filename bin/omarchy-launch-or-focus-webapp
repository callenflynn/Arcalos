#!/bin/bash

# arcalos:summary=Launch or focus on a given web app identified by the window-pattern.
# arcalos:args=<window-pattern> <url-and-flags...>

if (($# == 0)); then
  echo "Usage: arcalos-launch-or-focus-webapp [window-pattern] [url-and-flags...]"
  exit 1
fi

WINDOW_PATTERN="$1"
shift
LAUNCH_COMMAND="arcalos-launch-webapp $@"

exec arcalos-launch-or-focus "$WINDOW_PATTERN" "$LAUNCH_COMMAND"
