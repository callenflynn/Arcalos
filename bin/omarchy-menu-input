#!/bin/bash

# arcalos:summary=Prompt for text input with Walker
# arcalos:group=menu
# arcalos:name=input
# arcalos:args=prompt [walker args...]
# arcalos:examples=arcalos menu input Reminder|arcalos-menu-input "Reminder in minutes" --width 400

set -euo pipefail

prompt="${1:-Input}"
if (( $# > 0 )); then
  shift
fi

arcalos-launch-walker --dmenu --inputonly --width 295 --minheight 1 --maxheight 1 -p "$prompt…" "$@" 2>/dev/null
