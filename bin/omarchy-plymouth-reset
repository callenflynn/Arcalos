#!/bin/bash

# arcalos:summary=Restore the default arcalos Plymouth boot theme and SDDM login screen
# arcalos:requires-sudo=true

theme_dir="/usr/share/plymouth/themes/arcalos"

sudo find ~/.local/share/arcalos/default/plymouth -maxdepth 1 -type f -exec cp -t "$theme_dir/" {} +
sudo plymouth-set-default-theme arcalos

if arcalos-cmd-present limine-mkinitcpio; then
  sudo limine-mkinitcpio
else
  sudo mkinitcpio -P
fi

arcalos-refresh-sddm
