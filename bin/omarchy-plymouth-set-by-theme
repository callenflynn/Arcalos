#!/bin/bash

# arcalos:summary=Set the Plymouth boot theme from an arcalos theme
# arcalos:args=<theme-name>
# arcalos:requires-sudo=true

# Resolve a theme by name and apply its unlock.png + colors.toml as the
# Plymouth boot screen via arcalos-plymouth-set.

if [[ $# -ne 1 ]]; then
  echo "Usage: arcalos-plymouth-set-by-theme <theme-name>" >&2
  exit 1
fi

theme=$1

if [[ -d ~/.config/arcalos/themes/$theme ]]; then
  theme_dir=~/.config/arcalos/themes/$theme
else
  theme_dir="$ARCALOS_PATH/themes/$theme"
fi

bg=$(awk -F'"' '/^background/{print $2}' "$theme_dir/colors.toml")
text=$(awk -F'"' '/^foreground/{print $2}' "$theme_dir/colors.toml")

exec arcalos-plymouth-set "$bg" "$text" "$theme_dir/unlock.png"
