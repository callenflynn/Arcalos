#!/bin/bash

# arcalos:summary=Overwrite all the user Hyprland Lua configs in ~/.config/hypr with the arcalos defaults.

arcalos-refresh-config hypr/.luarc.json
arcalos-refresh-config hypr/autostart.lua
arcalos-refresh-config hypr/bindings.lua
arcalos-refresh-config hypr/input.lua
arcalos-refresh-config hypr/looknfeel.lua
arcalos-refresh-config hypr/hyprland.lua
arcalos-refresh-config hypr/monitors.lua
bash "$ARCALOS_PATH/install/config/arcalos-toggles.sh"
bash "$ARCALOS_PATH/install/config/detect-keyboard-layout.sh"
