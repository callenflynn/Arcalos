#!/bin/bash

# arcalos:summary=Overwrite the user config for the Plymouth drive decryption and boot sequence with the arcalos default and rebuild it.
# arcalos:requires-sudo=true

sudo cp -r ~/.local/share/arcalos/default/plymouth/* /usr/share/plymouth/themes/arcalos/
sudo plymouth-set-default-theme arcalos

if command -v limine-mkinitcpio &>/dev/null; then
  sudo limine-mkinitcpio
else
  sudo mkinitcpio -P
fi
