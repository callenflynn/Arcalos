#!/bin/bash

# arcalos:summary=Reinstall arcalos packages and reset default configs
# arcalos:requires-sudo=true

set -e

# Attempt to reinstall all default arcalos packages and reset all the default configs.

echo -e "This will reinstall all the default arcalos packages and reset all default configs.\nWarning: All user changes to configs will be lost.\n"

if gum confirm "Are you sure you want to reinstall and lose all config changes?"; then
  arcalos-reinstall-git
  arcalos-reinstall-pkgs
  arcalos-reinstall-configs

  gum confirm "System has been reinstalled. Reboot?" && arcalos-system-reboot
fi
