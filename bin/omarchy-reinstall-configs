#!/bin/bash

# arcalos:summary=Reset all arcalos user configs to the defaults
# arcalos:requires-sudo=true

set -e

# Overwrite all user configs with the arcalos defaults.

if (( EUID == 0 )); then
  echo "Error: This script should not be run as root"
  exit 1
fi

echo "Resetting all arcalos configs"
cp -R ~/.local/share/arcalos/config/* ~/.config/
cp ~/.local/share/arcalos/default/bashrc ~/.bashrc
echo '[[ -f ~/.bashrc ]] && . ~/.bashrc' | tee ~/.bash_profile >/dev/null

$(bash $ARCALOS_PATH/install/config/theme.sh)

arcalos-refresh-limine
arcalos-refresh-plymouth
arcalos-nvim-setup
