#!/bin/bash

# arcalos:summary=Reinstall the stable arcalos source directory from git

set -e

# Reinstall the arcalos configuration directory from the git source.

git clone --depth=1 --branch master "https://github.com/callenflynn/arcalos.git" ~/.local/share/arcalos-new >/dev/null
mv $ARCALOS_PATH ~/.local/share/arcalos-old
mv ~/.local/share/arcalos-new $ARCALOS_PATH
