#!/bin/bash

# arcalos:summary=Reinstall all default arcalos packages from the stable channel
# arcalos:requires-sudo=true

set -e

# Reinstall all default arcalos packages from the stable channel and downgrade any packages that are too new.

# Set the package repository to the stable mirrors
arcalos-refresh-pacman

# Downgrade any packages to the stable setup
sudo pacman -Suu --noconfirm

# Ensure all packages are installed
mapfile -t packages < <(grep -v '^#' "$ARCALOS_PATH/install/arcalos-base.packages" | grep -v '^$')
sudo pacman -Syu --noconfirm --needed "${packages[@]}"
