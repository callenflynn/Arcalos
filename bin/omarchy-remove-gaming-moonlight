#!/bin/bash

# arcalos:summary=Remove Moonlight and its configs and caches.
# arcalos:requires-sudo=true

set -e

arcalos-pkg-drop moonlight-qt

rm -rf \
  "$HOME/.config/Moonlight Game Streaming Project" \
  "$HOME/.cache/Moonlight Game Streaming Project"

echo ""
echo "Moonlight and its data have been removed."
