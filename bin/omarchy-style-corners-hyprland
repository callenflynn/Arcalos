#!/bin/bash

# arcalos:summary=Set or toggle shape of Hyprland window corners
# arcalos:args=[toggle|sharp|round]
# arcalos:examples=arcalos style corners hyprland toggle | arcalos style corners hyprland round | arcalos style corners hyprland sharp

case "${1:-toggle}" in
  round) set -- on ;;
  sharp) set -- off ;;
  toggle) ;;
  *)
    echo "Usage: arcalos-style-corners-hyprland [toggle|sharp|round]"
    exit 1
    ;;
esac

arcalos-hyprland-toggle rounded-corners "$1"
