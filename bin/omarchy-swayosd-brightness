#!/bin/bash

# arcalos:summary=Display brightness level using SwayOSD on the current monitor.
# arcalos:args=<0-100>
# arcalos:examples=arcalos swayosd brightness 0 | arcalos swayosd brightness 50 | arcalos swayosd brightness 100

percent="$1"

progress="$(awk -v p="$percent" 'BEGIN{printf "%.2f", p/100}')"
[[ $progress == "0.00" ]] && progress="0.01"

arcalos-swayosd-client \
  --custom-icon display-brightness-symbolic \
  --custom-progress "$progress" \
  --custom-progress-text "$(printf '%3d%%' "$percent")"
