#!/bin/bash

# arcalos:summary=Lock the computer and turn off the display
# arcalos:group=system
# arcalos:name=lock
# arcalos:examples=arcalos system lock

if ! pidof hyprlock >/dev/null; then
  (
    hyprlock
    arcalos-system-wake
  ) &
fi

# Set keyboard layout to default (first layout)
hyprctl switchxkblayout all 0 > /dev/null 2>&1

# Ensure 1password is locked
if pgrep -x "1password" >/dev/null; then
  1password --lock &
fi

# Avoid running screensaver when locked
pkill -f org.arcalos.screensaver

if [[ ${ARCALOS_LOCK_ONLY:-false} != "true" ]]; then
  (
    sleep 3
    pidof hyprlock >/dev/null || exit 0
    arcalos-brightness-keyboard off
    arcalos-brightness-display off
  ) &
fi
