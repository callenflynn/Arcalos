#!/bin/bash

# arcalos:summary=Log out after closing application windows
# arcalos:examples=arcalos logout | arcalos system logout
# arcalos:aliases=arcalos logout

nohup bash -c "sleep 2 && uwsm stop" >/dev/null 2>&1 &

# Now close all windows
arcalos-hyprland-window-close-all
sleep 1 # Allow apps like Chrome to shutdown correctly
