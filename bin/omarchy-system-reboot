#!/bin/bash

# arcalos:summary=Reboot after closing application windows
# arcalos:examples=arcalos reboot | arcalos system reboot
# arcalos:aliases=arcalos reboot

arcalos-state clear re*-required

# Schedule the reboot to happen after closing windows (detached from terminal)
nohup bash -c "sleep 2 && systemctl reboot --no-wall" >/dev/null 2>&1 &

# Now close all windows
arcalos-hyprland-window-close-all
sleep 1 # Allow apps like Chrome to shutdown correctly
