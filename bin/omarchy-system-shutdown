#!/bin/bash

# arcalos:summary=Shut down after closing application windows
# arcalos:examples=arcalos shutdown | arcalos system shutdown
# arcalos:aliases=arcalos shutdown

arcalos-state clear re*-required

# Schedule the shutdown to happen after closing windows (detached from terminal)
nohup bash -c "sleep 2 && systemctl poweroff --no-wall" >/dev/null 2>&1 &

# Now close all windows
arcalos-hyprland-window-close-all
sleep 1 # Allow apps like Chrome to shutdown correctly
