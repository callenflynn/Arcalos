#!/bin/bash

# arcalos:summary=Cache background switcher thumbnails for the current theme

theme_name=$(cat "$HOME/.config/arcalos/current/theme.name" 2>/dev/null)

arcalos-menu-images \
  --cache-only \
  "$HOME/.config/arcalos/current/theme/backgrounds" \
  "$HOME/.config/arcalos/backgrounds/$theme_name"
