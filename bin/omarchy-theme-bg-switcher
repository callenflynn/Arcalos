#!/bin/bash

# arcalos:summary=Open the arcalos background switcher
# arcalos:group=theme
# arcalos:name=bg-switcher
# arcalos:aliases=arcalos background

ARCALOS_PATH=${ARCALOS_PATH:-$HOME/.local/share/arcalos}
theme_name=$(cat "$HOME/.config/arcalos/current/theme.name" 2>/dev/null)
current_background=$(readlink -f "$HOME/.config/arcalos/current/background" 2>/dev/null)

arcalos-menu-images \
  --selected "$current_background" \
  "$HOME/.config/arcalos/current/theme/backgrounds" \
  "$HOME/.config/arcalos/backgrounds/$theme_name"
