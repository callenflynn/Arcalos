#!/bin/bash

# arcalos:summary=List available themes
# arcalos:examples=arcalos theme list | arcalos theme set "Tokyo Night"

{
  find ~/.config/arcalos/themes/ -mindepth 1 -maxdepth 1 \( -type d -o -type l \) -printf '%f\n'
  find "$ARCALOS_PATH/themes/" -mindepth 1 -maxdepth 1 -type d -printf '%f\n'
} | sort -u | while read -r name; do
  echo "$name" | sed -E 's/(^|-)([a-z])/\1\u\2/g; s/-/ /g'
done
