#!/bin/bash

# arcalos:summary=Apply an Arcalos theme
# arcalos:args=<theme-name>
# arcalos:examples=arcalos theme list | arcalos theme set "Tokyo Night"

if [[ -z $1 ]]; then
  echo "Usage: arcalos-theme-set <theme-name>"
  exit 1
fi

CURRENT_THEME_PATH="$HOME/.config/arcalos/current/theme"
NEXT_THEME_PATH="$HOME/.config/arcalos/current/next-theme"
USER_THEMES_PATH="$HOME/.config/arcalos/themes"
ARCALOS_THEMES_PATH="$ARCALOS_PATH/themes"

THEME_NAME=$(echo "$1" | sed -E 's/<[^>]+>//g' | tr '[:upper:]' '[:lower:]' | tr ' ' '-')

if [[ ! -d $ARCALOS_THEMES_PATH/$THEME_NAME ]] && [[ ! -d $USER_THEMES_PATH/$THEME_NAME ]]; then
  echo "Theme '$THEME_NAME' does not exist"
  exit 1
fi

# Setup clean next theme directory (for atomic theme config swapping)
rm -rf "$NEXT_THEME_PATH"
mkdir -p "$NEXT_THEME_PATH"

# Copy official theme first, then overlay user customizations on top
cp -r "$ARCALOS_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null
cp -r "$USER_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null

# Generate colors.toml from alacritty.toml if theme is missing colors.toml
if [[ ! -f $NEXT_THEME_PATH/colors.toml && -f $NEXT_THEME_PATH/alacritty.toml ]]; then
  arcalos-theme-colors-from-alacritty "$NEXT_THEME_PATH"
fi

# Generate dynamic configs
arcalos-theme-set-templates

# Swap next theme in as current
rm -rf "$CURRENT_THEME_PATH"
mv "$NEXT_THEME_PATH" "$CURRENT_THEME_PATH"

# Store theme name for reference
echo "$THEME_NAME" >"$HOME/.config/arcalos/current/theme.name"

# Change background with theme
if [[ $ARCALOS_THEME_SKIP_BACKGROUND != "1" ]]; then
  arcalos-theme-bg-next
fi

# Restart components to apply new theme
if pgrep -x waybar >/dev/null; then
  arcalos-restart-waybar
fi
arcalos-restart-swayosd
arcalos-restart-terminal
arcalos-restart-hyprctl
arcalos-restart-btop
arcalos-restart-opencode
arcalos-restart-mako
arcalos-restart-helix

# Change app-specific themes
arcalos-theme-set-foot
arcalos-theme-set-gnome
arcalos-theme-set-browser
arcalos-theme-set-vscode
arcalos-theme-set-obsidian
arcalos-theme-set-keyboard

# Call hook on theme set
arcalos-hook theme-set "$THEME_NAME" >/dev/null

# Warm the background selector cache after the theme is applied, off the critical path.
arcalos-theme-bg-cache >/dev/null 2>&1 &
