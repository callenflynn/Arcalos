#!/bin/bash

# arcalos:summary=Update Arcalos and system packages
# arcalos:args=[-y]
# arcalos:examples=arcalos update | arcalos update -y
# arcalos:requires-sudo=true

set -e

# Run the update inside a PTY so pacman/yay keep showing download progress
# while still logging the full session for later analysis.
if [[ -z $ARCALOS_UPDATE_LOGGED ]]; then
  script_command=$(printf '%q ' "$0" "$@")
  exec env ARCALOS_UPDATE_LOGGED=1 script -qefc "$script_command" "/tmp/arcalos-update.log"
fi

trap 'echo ""; echo -e "\033[0;31mSomething went wrong during the update!\n\nPlease review the output above carefully, correct the error, and retry the update.\n\nIf you need assistance, get help from the community at https://arcalos.org/discord\033[0m"' ERR

if [[ $1 == "-y" ]] || arcalos-update-confirm; then
  arcalos-snapshot create || (($? == 127))
  arcalos-update-git
  arcalos-update-perform
fi
