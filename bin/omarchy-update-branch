#!/bin/bash

# arcalos:summary=Switch arcalos branches and update from the selected branch
# arcalos:args=<branch>

set -e

if (($# == 0)); then
  echo "Usage: arcalos-update-branch [master|dev]"
  exit 1
fi

branch="$1"

# Snapshot before switching branch
arcalos-snapshot create || (( $? == 127 ))

if ! git -C "$ARCALOS_PATH" diff --quiet || ! git -C "$ARCALOS_PATH" diff --cached --quiet; then
  stashed=true
  git -C "$ARCALOS_PATH" stash push -u -m "Autostash before switching to $branch"
else
  stashed=false
fi

# Switch branches
git -C "$ARCALOS_PATH" switch "$branch"

# Reapply stash if we made one
if [[ $stashed == "true" ]]; then
  if ! git -C "$ARCALOS_PATH" stash pop; then
    echo "⚠️ Conflicts when applying stash — stash kept"
  fi
fi

# Update the system from the new branch
arcalos-update-perform
