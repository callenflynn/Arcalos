#!/bin/bash

# arcalos:summary=Run the full arcalos update pipeline
# arcalos:requires-sudo=true

set -e

# Ensure screensaver/sleep doesn't set in during updates
hyprctl dispatch 'hl.dsp.window.tag({ tag = "+noidle" })' &>/dev/null || hyprctl dispatch tagwindow +noidle &>/dev/null || true

# Perform all update steps
arcalos-update-keyring
arcalos-update-available-reset
arcalos-update-system-pkgs
arcalos-migrate
arcalos-update-aur-pkgs
arcalos-update-orphan-pkgs
arcalos-hook post-update

arcalos-update-analyze-logs

arcalos-update-restart

# Re-enable screensaver/sleep after updates
hyprctl dispatch 'hl.dsp.window.tag({ tag = "-noidle" })' &>/dev/null || hyprctl dispatch tagwindow -- -noidle &>/dev/null || true
