[Unit]
Description=Recover the internal monitor toggle when no external display is connected
Before=graphical-session-pre.target
ConditionPathExists=%h/.local/state/arcalos/toggles/hypr/internal-monitor-disable.lua

[Service]
Type=oneshot
ExecStart=%h/.local/share/arcalos/bin/arcalos-hw-recover-internal-monitor

[Install]
WantedBy=graphical-session-pre.target
