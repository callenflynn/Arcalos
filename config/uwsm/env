# Changes require a restart to take effect.

# Ensure Arcalos bins are in the path
export ARCALOS_PATH=$HOME/.local/share/arcalos
export PATH=$ARCALOS_PATH/bin:$PATH:$HOME/.local/bin

# Set default terminal and editor
source ~/.config/uwsm/default

# Activate mise if present on the system
arcalos-cmd-present mise && eval "$(mise activate bash --shims)"
